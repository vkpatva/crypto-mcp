{
  "name": "crypto-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for EVM blockchain operations via Alchemy RPC",
  "type": "module",
  "bin": {
    "crypto-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
