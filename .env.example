# ---- Wallet key material (provide EXACTLY ONE of the two) ----
# A BIP-39 mnemonic phrase...
MNEMONIC=
# ...OR a hex private key (0x-prefixed)
PRIVATE_KEY=

# Optional HD derivation path (only used with MNEMONIC). Defaults to ethers' default.
# DERIVATION_PATH=m/44'/60'/0'/0/0

# ---- Alchemy (required) ----
ALCHEMY_API_KEY=

# ---- Networking ----
# Default network used when a tool call omits `network`.
# Mainnets: ethereum | base | arbitrum | optimism | polygon
# Testnets: sepolia | base-sepolia | arbitrum-sepolia | optimism-sepolia | polygon-amoy
DEFAULT_NETWORK=polygon-amoy

# Transport: stdio (default) | http
TRANSPORT=stdio
# Port for the Streamable HTTP transport (only used when TRANSPORT=http)
PORT=3000
